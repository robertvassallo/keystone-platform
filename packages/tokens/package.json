{
  "name": "@keystone/tokens",
  "version": "0.0.0",
  "private": true,
  "description": "Design tokens — primitive + semantic. Emits CSS custom properties consumed by the Tailwind preset and the app stylesheets.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./dist/tokens.css": "./dist/tokens.css"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "node ./build.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@keystone/config": "workspace:*",
    "typescript": "^5.7.2"
  }
}
